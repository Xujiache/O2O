{
  "name": "e2e-app",
  "version": "0.0.1",
  "private": true,
  "description": "O2O 商户端 / 骑手端 APP E2E 测试 (WebdriverIO + Appium) — Sprint 4 / W4.E.2",
  "scripts": {
    "test:android": "wdio run wdio.conf.ts --capabilities android",
    "test:ios": "wdio run wdio.conf.ts --capabilities ios",
    "test:merchant:android": "wdio run wdio.conf.ts --capabilities android --spec ./tests/merchant/*.spec.ts",
    "test:rider:android": "wdio run wdio.conf.ts --capabilities android --spec ./tests/rider/*.spec.ts"
  },
  "devDependencies": {
    "@wdio/cli": "^8.39.0",
    "@wdio/local-runner": "^8.39.0",
    "@wdio/mocha-framework": "^8.39.0",
    "@wdio/spec-reporter": "^8.39.0",
    "@wdio/appium-service": "^8.39.0",
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.14.10",
    "appium": "^2.5.0",
    "appium-uiautomator2-driver": "^3.6.0",
    "appium-xcuitest-driver": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "webdriverio": "^8.39.0"
  }
}
