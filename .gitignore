# ----------------------------------------------------------------------------
# O2O 跑腿+外卖 平台 monorepo 根 .gitignore
# 覆盖 5 端（用户端/商户端/骑手端/管理后台/后端）+ 部署配置
# ----------------------------------------------------------------------------

# 依赖目录
node_modules/
.pnpm-store/
jspm_packages/

# 构建产物
dist/
dist-ssr/
build/
out/
unpackage/            # uni-app 打包目录
.output/
.nuxt/
.next/
.turbo/
.parcel-cache/
.cache/
.vite/
.rollup.cache/
.tsbuildinfo
*.tsbuildinfo

# 测试与覆盖率
coverage/
.nyc_output/
*.lcov

# 日志
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 环境变量（保留 .env.example 用于仓库说明）
.env
.env.local
.env.*.local
.env.development.local
.env.production.local
.env.test.local

# IDE / 编辑器
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.recommended.json
.history/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.cursorrules
.kiro/
.trae/

# 操作系统
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# 运行时 / 临时文件
*.pid
*.seed
*.pid.lock
tmp/
temp/
.tmp/

# 自动生成文件（uni-app / unplugin-auto-import / unplugin-vue-components）
auto-imports.d.ts
components.d.ts
.auto-import.json
src/types/import/auto-imports.d.ts
src/types/import/components.d.ts

# Docker 运行时卷（仅本地 volume，compose 文件必须入库）
部署/docker-data/
部署/**/data/

# Redis 持久化快照（本地 redis-cli SAVE 产物，不入库）
dump.rdb
*.rdb

# Claude Code session 数据（每次会话/工作区变化，不应入库）
.claude/

# IDE 自动产物（sessionId 每次重启变化，不应入库）
.cursor/mcp.json
# IDE 插件自动生成的 rule（如 my-mcp，每次启用后会自动写入）
.cursor/rules/*.mdc

# Lint 临时输出（任意子目录）
lint_output.txt
**/lint.json

# 其他
*.local
*.tgz
.eslintcache
.stylelintcache
