{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u-(.*)": "uview-plus/components/u-$1/u-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "首页"
      }
    },
    {
      "path": "pages/takeout/index",
      "style": {
        "navigationBarTitleText": "外卖点餐"
      }
    },
    {
      "path": "pages/errand/index",
      "style": {
        "navigationBarTitleText": "同城跑腿"
      }
    },
    {
      "path": "pages/order/index",
      "style": {
        "navigationBarTitleText": "订单"
      }
    },
    {
      "path": "pages/user/index",
      "style": {
        "navigationBarTitleText": "我的"
      }
    },
    {
      "path": "pages/pay/index",
      "style": {
        "navigationBarTitleText": "支付"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "O2O 用户端",
    "navigationBarBackgroundColor": "#FFFFFF",
    "backgroundColor": "#F5F6F8"
  },
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#FF6B35",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "black",
    "list": [
      { "pagePath": "pages/index/index", "text": "首页" },
      { "pagePath": "pages/takeout/index", "text": "外卖" },
      { "pagePath": "pages/errand/index", "text": "跑腿" },
      { "pagePath": "pages/order/index", "text": "订单" },
      { "pagePath": "pages/user/index", "text": "我的" }
    ]
  }
}
