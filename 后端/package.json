{
  "name": "后端",
  "version": "0.1.0",
  "private": true,
  "description": "O2O 平台后端（NestJS 10 + TypeScript + TypeORM + Redis + RabbitMQ + MinIO）",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=8.8.0"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:unit": "jest --config jest-unit.config.js",
    "test:integration": "jest --config jest-integration.config.js --runInBand",
    "test:watch": "jest --config jest-unit.config.js --watch",
    "test:cov": "jest --config jest-unit.config.js --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/bullmq": "^10.2.0",
    "@nestjs/cache-manager": "^2.2.2",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/typeorm": "^10.0.2",
    "@sentry/node": "^9.0.0",
    "@turf/boolean-point-in-polygon": "^7.3.4",
    "@turf/helpers": "^7.3.4",
    "@turf/turf": "^7.3.4",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "ali-oss": "^6.23.0",
    "amqplib": "^0.10.4",
    "bcryptjs": "^3.0.3",
    "bignumber.js": "^11.0.0",
    "bullmq": "^5.12.0",
    "cache-manager": "^5.7.0",
    "cache-manager-ioredis-yet": "^2.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "exceljs": "^4.4.0",
    "ioredis": "^5.4.0",
    "joi": "^17.13.3",
    "minio": "^8.0.0",
    "multer": "^2.1.1",
    "mysql2": "^3.11.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@nestjs/testing": "^10.4.0",
    "@types/ali-oss": "^6.23.3",
    "@types/amqplib": "^0.10.5",
    "@types/express": "^5.0.0",
    "@types/geojson": "^7946.0.16",
    "@types/jest": "^29.5.13",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.7.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.9.0",
    "@typescript-eslint/parser": "^8.9.0",
    "eslint": "^9.11.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.6.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "collectCoverageFrom": [
      "modules/file/file.service.ts",
      "modules/file/adapters/storage.adapter.ts",
      "modules/file/utils/mime.util.ts",
      "modules/file/utils/watermark.util.ts",
      "modules/map/map.service.ts",
      "modules/map/geo.util.ts",
      "modules/map/rider-location.service.ts",
      "modules/order/state-machine/**/*.ts",
      "modules/finance/services/account.service.ts",
      "modules/finance/services/settlement.service.ts",
      "modules/payment/services/payment-state-machine.ts",
      "modules/product/inventory.service.ts",
      "modules/orchestration/services/**/*.ts",
      "utils/crypto.util.ts",
      "!**/*.spec.ts",
      "!**/*.module.ts",
      "!**/dto/**",
      "!**/index.ts"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
