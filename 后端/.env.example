# ----------------------------------------------------------------------------
# O2O 后端 环境变量样例（.env.example）
# 复制为 .env.development / .env.production，填入实际值
# 对齐 DESIGN_P1 §七
# ----------------------------------------------------------------------------

# ========== 应用 ==========
NODE_ENV=development
APP_NAME=o2o-server
APP_VERSION=0.1.0
APP_PORT=3000
APP_PREFIX=/api/v1

# ========== MySQL ==========
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=o2o_root_2026
DB_NAME=o2o_platform
DB_SYNCHRONIZE=false
DB_LOGGING=false

# ========== Redis ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=o2o_redis_2026
REDIS_DB=0

# ========== JWT ==========
# 生产环境必须使用 64+ 位随机串
JWT_SECRET=please-replace-with-a-64-char-random-string-in-production!!
JWT_EXPIRES_IN=7200

# ========== RabbitMQ ==========
RABBITMQ_URL=amqp://o2o:o2o_rmq_2026@localhost:5672
RABBITMQ_QUEUE_PREFIX=o2o

# ========== MinIO / 对象存储 ==========
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=o2o
MINIO_SECRET_KEY=o2o_minio_2026
MINIO_BUCKET=o2o-platform

# ========== 第三方服务（生产填写） ==========
WECHAT_MP_APPID=
WECHAT_MP_SECRET=
WECHAT_PAY_MCHID=
WECHAT_PAY_APIV3_KEY=
ALIPAY_APPID=
ALIPAY_PRIVATE_KEY=
SMS_AK=
SMS_SK=
PUSH_PROVIDER=jpush
MAP_PROVIDER=amap
MAP_AK=

# ========== 日志 ==========
LOG_LEVEL=debug

# ========== Sentry（P9/W2.C.1，可选；为空则禁用上报） ==========
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ========== WeChat Pay V3（P9/W3.C，可选；任一关键项为空则 provider 自动 no-op） ==========
# 商户号
WECHAT_PAY_V3_MCHID=
# 公众号 / 小程序 AppId
WECHAT_PAY_V3_APPID=
# 商户证书序列号（10 进制 / 16 进制字符串）
WECHAT_PAY_V3_SERIAL_NO=
# APIv3 密钥（32 字节 utf8 字符串，AES-GCM 解密用）
WECHAT_PAY_V3_API_V3_KEY=
# 商户私钥 PEM（含 -----BEGIN PRIVATE KEY-----；多行可用 \n 转义或 docker secrets 注入）
WECHAT_PAY_V3_PRIVATE_KEY=
# 平台公钥 PEM（用于回调验签；为空则回调一律 valid=false）
WECHAT_PAY_V3_PLATFORM_PUBLIC_KEY=
# 异步通知接收地址（例：https://api.example.com/api/v1/payment/callback/wechat）
WECHAT_PAY_V3_NOTIFY_URL=
# 沙箱 / 生产 base URL（默认生产）
WECHAT_PAY_V3_SANDBOX_BASE_URL=https://api.mch.weixin.qq.com

# ========== Alipay（P9/W3.C，可选；任一关键项为空则 provider 自动 no-op） ==========
ALIPAY_APP_ID=
# 应用私钥 PEM（RSA2 / 2048）
ALIPAY_PRIVATE_KEY=
# 支付宝公钥 PEM（异步通知验签用）
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=
# 沙箱：https://openapi-sandbox.dl.alipaydev.com/gateway.do
# 生产：https://openapi.alipay.com/gateway.do
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# ========== JPush（P9/W5.B 极光推送 V3，可选） ==========
JPUSH_APP_KEY=
JPUSH_MASTER_SECRET=
JPUSH_BASE_URL=https://api.jpush.cn
# iOS APNs 是否走生产环境（默认 false 走沙箱）
JPUSH_APNS_PRODUCTION=false

# ========== 高德 Web 服务（P9/W5.B 服务端高级路径 / 距离矩阵 / 高精度逆地理） ==========
AMAP_SERVER_KEY=
AMAP_SERVER_BASE_URL=https://restapi.amap.com

# ========== RSA 加密传输（P9/W5.C 管理员登录密码加密） ==========
# 私钥 + 公钥 keypair TTL（小时；默认 24h）；过期自动轮换
RSA_KEY_TTL_HOURS=24

# ========== 阿里云短信（P9/W5.C，可选；缺凭证 provider no-op） ==========
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMS_REGION=cn-hangzhou

# ========== 阿里云号码中心 AXN 隐私号（P9/W5.E，可选） ==========
ALIYUN_AXN_ACCESS_KEY_ID=
ALIYUN_AXN_ACCESS_KEY_SECRET=
ALIYUN_AXN_POOL_KEY=
ALIYUN_AXN_REGION=cn-hangzhou
ALIYUN_AXN_ENDPOINT=https://dyplsapi.aliyuncs.com/

# ========== 微信小程序订阅消息（P9/W5.E，可选） ==========
WX_APP_ID=
WX_APP_SECRET=
WX_API_BASE_URL=https://api.weixin.qq.com
# 订阅消息模板 ID 别名映射（JSON 字符串），例 {"ORDER_PAID":"<wx_template_id>","ORDER_FINISHED":"..."}
WX_SUBSCRIBE_TEMPLATES={}
