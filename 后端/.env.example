# ----------------------------------------------------------------------------
# O2O 后端 环境变量样例（.env.example）
# 复制为 .env.development / .env.production，填入实际值
# 对齐 DESIGN_P1 §七
# ----------------------------------------------------------------------------

# ========== 应用 ==========
NODE_ENV=development
APP_NAME=o2o-server
APP_VERSION=0.1.0
APP_PORT=3000
APP_PREFIX=/api/v1

# ========== MySQL ==========
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=o2o_root_2026
DB_NAME=o2o_platform
DB_SYNCHRONIZE=false
DB_LOGGING=false

# ========== Redis ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=o2o_redis_2026
REDIS_DB=0

# ========== JWT ==========
# 生产环境必须使用 64+ 位随机串
JWT_SECRET=please-replace-with-a-64-char-random-string-in-production!!
JWT_EXPIRES_IN=7200

# ========== RabbitMQ ==========
RABBITMQ_URL=amqp://o2o:o2o_rmq_2026@localhost:5672
RABBITMQ_QUEUE_PREFIX=o2o

# ========== MinIO / 对象存储 ==========
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=o2o
MINIO_SECRET_KEY=o2o_minio_2026
MINIO_BUCKET=o2o-platform

# ========== 第三方服务（生产填写） ==========
WECHAT_MP_APPID=
WECHAT_MP_SECRET=
WECHAT_PAY_MCHID=
WECHAT_PAY_APIV3_KEY=
ALIPAY_APPID=
ALIPAY_PRIVATE_KEY=
SMS_AK=
SMS_SK=
PUSH_PROVIDER=jpush
MAP_PROVIDER=amap
MAP_AK=

# ========== 日志 ==========
LOG_LEVEL=debug
