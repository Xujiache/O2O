# ----------------------------------------------------------------------------
# O2O 跑腿+外卖 平台 pnpm 配置
# 依据 docs/P1_项目初始化/CONSENSUS_P1_项目初始化.md §四 风险应对
# ----------------------------------------------------------------------------

# 严格按 engines 字段校验 Node/pnpm 版本
engine-strict=true

# 不做幻影依赖提升，避免 NestJS/uni-app 依赖污染（CONSENSUS 风险 3）
shamefully-hoist=false

# 自动安装 peer 依赖（uView Plus、uni-app 存在较多 peerDependencies）
auto-install-peers=true

# 关闭严格 peer 校验（uni-app 生态部分包 peer 声明不精确）
strict-peer-dependencies=false

# 兼容老包的旧版锁定算法，减少 Windows 中文路径下的冲突
node-linker=isolated

# 使用阿里云镜像加速（开发加速，生产/CI 建议覆盖为官方源）
registry=https://registry.npmmirror.com/

# @dcloudio scope 定向到官方 registry：npmmirror 对 uni-app 的 alpha 子包同步存在延迟
# （例如 @dcloudio/uni-app-vue@3.0.0-alpha-* 在 npmmirror 上缺失），定向到官方源解决
@dcloudio:registry=https://registry.npmjs.org/

# 修复：pinia 3 → @vue/devtools-api → @vue/devtools-kit → @vue/devtools-shared
# 这条 transitive 链在 pnpm isolated + uni-app Vite 5 下存在已知解析失败。
# 解决方案：通过 public-hoist-pattern 把 devtools-kit 及其全部子依赖提升到顶层，
# 使三端 uni-app 项目的 Vite 能够正确解析这些模块。
public-hoist-pattern[]=@vue/devtools-shared
public-hoist-pattern[]=@vue/devtools-kit
public-hoist-pattern[]=@vue/devtools-api
public-hoist-pattern[]=perfect-debounce
public-hoist-pattern[]=hookable
public-hoist-pattern[]=birpc
