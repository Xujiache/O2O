{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u-(.*)": "uview-plus/components/u-$1/u-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/login/index",
      "style": {
        "navigationBarTitleText": "登录",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/hall/index",
      "style": {
        "navigationBarTitleText": "接单大厅"
      }
    },
    {
      "path": "pages/delivery/index",
      "style": {
        "navigationBarTitleText": "订单配送"
      }
    },
    {
      "path": "pages/wallet/index",
      "style": {
        "navigationBarTitleText": "我的钱包"
      }
    },
    {
      "path": "pages/attendance/index",
      "style": {
        "navigationBarTitleText": "考勤统计"
      }
    },
    {
      "path": "pages/message/index",
      "style": {
        "navigationBarTitleText": "消息中心"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "O2O 骑手端",
    "navigationBarBackgroundColor": "#00B578",
    "backgroundColor": "#F5F6F8"
  },
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#00B578",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "black",
    "list": [
      { "pagePath": "pages/hall/index", "text": "接单" },
      { "pagePath": "pages/delivery/index", "text": "配送" },
      { "pagePath": "pages/wallet/index", "text": "钱包" },
      { "pagePath": "pages/attendance/index", "text": "考勤" },
      { "pagePath": "pages/message/index", "text": "消息" }
    ]
  }
}
