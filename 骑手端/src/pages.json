{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u-(.*)": "uview-plus/components/u-$1/u-$1.vue",
      "^Biz(.*)": "@/components/biz/Biz$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/login/index",
      "style": {
        "navigationBarTitleText": "骑手登录",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/home/workbench",
      "style": {
        "navigationBarTitleText": "工作台",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/hall/index",
      "style": {
        "navigationBarTitleText": "接单大厅",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/order/index",
      "style": {
        "navigationBarTitleText": "我的订单",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/wallet/index",
      "style": {
        "navigationBarTitleText": "我的钱包"
      }
    },
    {
      "path": "pages/profile/index",
      "style": {
        "navigationBarTitleText": "我的"
      }
    }
  ],
  "subPackages": [
    {
      "root": "pages-login",
      "pages": [
        { "path": "sms-login", "style": { "navigationBarTitleText": "短信登录" } },
        { "path": "register", "style": { "navigationBarTitleText": "骑手注册" } },
        {
          "path": "qualification",
          "style": { "navigationBarTitleText": "资质上传" }
        },
        { "path": "deposit", "style": { "navigationBarTitleText": "保证金缴纳" } },
        { "path": "audit-status", "style": { "navigationBarTitleText": "审核状态" } },
        { "path": "agreement", "style": { "navigationBarTitleText": "骑手协议" } },
        { "path": "reset-password", "style": { "navigationBarTitleText": "重置密码" } }
      ]
    },
    {
      "root": "pages-hall",
      "pages": [
        {
          "path": "preference",
          "style": { "navigationBarTitleText": "接单偏好" }
        },
        { "path": "detail", "style": { "navigationBarTitleText": "订单详情" } }
