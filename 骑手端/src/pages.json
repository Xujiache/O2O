        { "path": "security", "style": { "navigationBarTitleText": "账号安全" } },
        { "path": "help", "style": { "navigationBarTitleText": "帮助中心" } },
        { "path": "feedback", "style": { "navigationBarTitleText": "意见反馈" } },
        { "path": "about", "style": { "navigationBarTitleText": "关于我们" } },
        { "path": "emergency", "style": { "navigationBarTitleText": "紧急求助" } }
      ]
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "O2O 骑手端",
    "navigationBarBackgroundColor": "#00B578",
    "backgroundColor": "#F5F7FA"
  },
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#00B578",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "black",
    "list": [
      { "pagePath": "pages/home/workbench", "text": "工作台" },
      { "pagePath": "pages/hall/index", "text": "接单" },
      { "pagePath": "pages/order/index", "text": "订单" },
      { "pagePath": "pages/wallet/index", "text": "钱包" },
      { "pagePath": "pages/profile/index", "text": "我的" }
    ]
  }
}
