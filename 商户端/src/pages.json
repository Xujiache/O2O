{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u-(.*)": "uview-plus/components/u-$1/u-$1.vue",
      "^Biz(.*)": "@/components/biz/Biz$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/login/index",
      "style": {
        "navigationBarTitleText": "登录",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/home/workbench",
      "style": {
        "navigationBarTitleText": "工作台",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/order/index",
      "style": {
        "navigationBarTitleText": "订单管理",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/product/index",
      "style": {
        "navigationBarTitleText": "商品管理"
      }
    },
    {
      "path": "pages/finance/index",
      "style": {
        "navigationBarTitleText": "财务结算"
      }
    },
    {
      "path": "pages/profile/index",
      "style": {
        "navigationBarTitleText": "我的"
      }
    }
  ],
  "subPackages": [
    {
      "root": "pages-login",
      "pages": [
        { "path": "sms-login", "style": { "navigationBarTitleText": "短信登录" } },
        { "path": "register", "style": { "navigationBarTitleText": "商户入驻" } },
        { "path": "qualification", "style": { "navigationBarTitleText": "资质上传" } },
        { "path": "audit-status", "style": { "navigationBarTitleText": "审核状态" } },
        { "path": "reset-password", "style": { "navigationBarTitleText": "重置密码" } },
        { "path": "agreement", "style": { "navigationBarTitleText": "用户协议" } }
      ]
    },
    {
      "root": "pages-shop",
      "pages": [
        { "path": "edit", "style": { "navigationBarTitleText": "店铺信息" } },
        { "path": "business-hour", "style": { "navigationBarTitleText": "营业时间" } },
        { "path": "delivery-area", "style": { "navigationBarTitleText": "配送范围" } },
        { "path": "delivery-config", "style": { "navigationBarTitleText": "配送设置" } },
        { "path": "review-list", "style": { "navigationBarTitleText": "评价管理" } },
        { "path": "review-reply", "style": { "navigationBarTitleText": "回复评价" } },
        { "path": "review-appeal", "style": { "navigationBarTitleText": "申诉评价" } }
      ]
    },
    {
      "root": "pages-order",
      "pages": [
        { "path": "detail", "style": { "navigationBarTitleText": "订单详情" } },
        { "path": "refund-audit", "style": { "navigationBarTitleText": "退款审核" } },
        { "path": "abnormal", "style": { "navigationBarTitleText": "异常上报" } },
        { "path": "print-setting", "style": { "navigationBarTitleText": "打印设置" } }
      ]
    },
    {
      "root": "pages-product",
      "pages": [
        { "path": "category", "style": { "navigationBarTitleText": "商品分类" } },
        { "path": "edit", "style": { "navigationBarTitleText": "编辑商品" } },
        { "path": "sku-edit", "style": { "navigationBarTitleText": "SKU 编辑" } },
        { "path": "discount", "style": { "navigationBarTitleText": "限时折扣" } }
      ]
    },
    {
      "root": "pages-finance",
      "pages": [
        { "path": "bill-list", "style": { "navigationBarTitleText": "账单明细" } },
        { "path": "withdraw", "style": { "navigationBarTitleText": "申请提现" } },
        { "path": "withdraw-record", "style": { "navigationBarTitleText": "提现记录" } },
        { "path": "bank-card", "style": { "navigationBarTitleText": "银行卡管理" } },
        { "path": "bank-card-edit", "style": { "navigationBarTitleText": "添加银行卡" } },
        { "path": "invoice-apply", "style": { "navigationBarTitleText": "申请发票" } },
        { "path": "invoice-list", "style": { "navigationBarTitleText": "发票记录" } },
        { "path": "invoice-header", "style": { "navigationBarTitleText": "发票抬头" } }
      ]
    }
  ],
  "preloadRule": {
    "pages/home/workbench": {
      "network": "all",
      "packages": ["pages-shop", "pages-order"]
    },
    "pages/order/index": {
      "network": "all",
      "packages": ["pages-order"]
    },
    "pages/product/index": {
      "network": "all",
      "packages": ["pages-product"]
    },
    "pages/finance/index": {
      "network": "all",
      "packages": ["pages-finance"]
    }
  },
  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "O2O 商户端",
    "navigationBarBackgroundColor": "#2F80ED",
    "backgroundColor": "#F5F7FA"
  },
  "tabBar": {
    "color": "#909399",
    "selectedColor": "#2F80ED",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "black",
    "list": [
      { "pagePath": "pages/home/workbench", "text": "工作台" },
      { "pagePath": "pages/order/index", "text": "订单" },
      { "pagePath": "pages/product/index", "text": "商品" },
      { "pagePath": "pages/finance/index", "text": "财务" },
      { "pagePath": "pages/profile/index", "text": "我的" }
    ]
  }
}
