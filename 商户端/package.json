    "build:app-ios": "uni build -p app-ios",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,vue}\" --fix",
    "lint:check": "eslint \"src/**/*.{ts,vue}\" --max-warnings 0",
    "lint:stylelint": "stylelint \"src/**/*.{vue,scss,css}\" --fix",
    "lint:stylelint:check": "stylelint \"src/**/*.{vue,scss,css}\""
  },
