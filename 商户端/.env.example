# ----------------------------------------------------------------------------
# 商户端（uni-app APP）环境变量样例
# 复制为 .env / .env.development / .env.production 后填入实际值
# ----------------------------------------------------------------------------

# 应用基础
VITE_APP_ENV=development
VITE_APP_VERSION=0.1.0

# Sentry（P9/W2.C.2，可选；为空则禁用上报）
VITE_SENTRY_DSN=

# WebSocket（P9/Sprint 6 W6.B.2；为空则禁用 WS 连接）
VITE_WS_URL=wss://api.example.com/ws
