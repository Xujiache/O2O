# ----------------------------------------------------------------------------
# O2O 商户端 生产环境变量（prod）
# ----------------------------------------------------------------------------

VITE_APP_ENV=production
VITE_APP_NAME=o2o-merchant-client
VITE_APP_VERSION=0.1.0

VITE_API_BASE_URL=https://api.o2o.example.com/api/v1
VITE_API_TIMEOUT=15000
VITE_WS_BASE_URL=wss://api.o2o.example.com/ws

# 生产环境必须关闭 mock
VITE_USE_MOCK=0

VITE_MAP_PROVIDER=amap
VITE_MAP_AK=

VITE_PUSH_PROVIDER=jpush
VITE_PUSH_APPKEY=

VITE_BT_PRINTER_ENABLED=true

# Sentry 生产环境必填
VITE_SENTRY_DSN=
