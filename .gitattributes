# ----------------------------------------------------------------------------
# O2O 跑腿+外卖 平台 monorepo 根 .gitattributes
# 统一行尾为 LF，避免 Windows/Mac 差异污染 diff
# ----------------------------------------------------------------------------

# 默认文本文件使用 LF
* text=auto eol=lf

# 脚本 / 源代码 / 配置 强制 LF
*.sh       text eol=lf
*.bash     text eol=lf
*.ps1      text eol=crlf
*.bat      text eol=crlf
*.cmd      text eol=crlf

*.js       text eol=lf
*.cjs      text eol=lf
*.mjs      text eol=lf
*.jsx      text eol=lf
*.ts       text eol=lf
*.cts      text eol=lf
*.mts      text eol=lf
*.tsx      text eol=lf
*.vue      text eol=lf
*.json     text eol=lf
*.jsonc    text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.toml     text eol=lf
*.md       text eol=lf
*.html     text eol=lf
*.htm      text eol=lf
*.css      text eol=lf
*.scss     text eol=lf
*.less     text eol=lf
*.sass     text eol=lf
*.svg      text eol=lf
*.xml      text eol=lf
*.txt      text eol=lf

# Dockerfile / 环境文件
Dockerfile         text eol=lf
*.Dockerfile       text eol=lf
.dockerignore      text eol=lf
.editorconfig      text eol=lf
.gitignore         text eol=lf
.gitattributes     text eol=lf
.npmrc             text eol=lf
.prettierrc        text eol=lf

# 二进制资源
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.webp     binary
*.bmp      binary
*.tiff     binary
*.woff     binary
*.woff2    binary
*.eot      binary
*.ttf      binary
*.otf      binary
*.mp3      binary
*.mp4      binary
*.wav      binary
*.ogg      binary
*.pdf      binary
*.zip      binary
*.7z       binary
*.gz       binary
*.tar      binary
*.xz       binary
*.rar      binary

# GitHub 语言统计时忽略 vendor / 自动生成文件
docs/**           linguist-documentation
*.min.js          linguist-generated
pnpm-lock.yaml    linguist-generated
package-lock.json linguist-generated
yarn.lock         linguist-generated
